# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
.venv/
venv/
env/

# Test/coverage
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# Personal credentials — never commit
.env
.praxis/security/*
!.praxis/security/.gitkeep

# Personal wiki content — never commit
wiki/raw/*
!wiki/raw/.gitkeep
wiki/pages/*
!wiki/pages/.gitkeep
wiki/graph.json
wiki/index.md
wiki/log.md

# Operational state — never commit
.praxis/memory/*
!.praxis/memory/.gitkeep
.praxis/staging/*
!.praxis/staging/.gitkeep
.praxis/queue/*
!.praxis/queue/.gitkeep
.praxis/logs/*
!.praxis/logs/.gitkeep
.praxis/praxis.pid
.praxis/schedule/*

# Claude Code local settings override
.claude/settings.local.json

# Generated agent shim files (source of truth is praxis/agents/*.yaml)
# NOTE: existing tracked .claude/agents/*.md files remain in git history until
# a human runs: git rm --cached .claude/agents/*.md
.claude/agents/
STATUS.md
=1.0
