# Praxis — Environment Configuration
# Copy this file to .env and fill in the values you need.
# Only the Auth section is required; everything else is optional.

# ─── Auth (one of these is required) ────────────────────────────────
# Subscription OAuth token — flat cost, preferred.
# Get from: Claude subscription account at claude.ai
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token

# Pay-per-token API key — fallback if no OAuth token.
# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Workspace ──────────────────────────────────────────────────────
# Root directory for file operations (defaults to current directory)
# PRAXIS_WORKSPACE_ROOT=/path/to/your/project

# Durable memory directory (defaults to $WORKSPACE_ROOT/.praxis/memory)
# PRAXIS_MEMORY_ROOT=/path/to/memory

# ─── Runtime Selection ──────────────────────────────────────────────
# Which runtime to use: claude (default), local, or cloud
# PRAXIS_RUNTIME=claude

# Override the default Claude model (default: claude-sonnet-4-6)
# PRAXIS_MODEL=claude-sonnet-4-6

# ─── Local Runtime (Ollama / vLLM / llama.cpp) ─────────────────────
# Requires: pip install praxis[local]
# PRAXIS_LOCAL_BASE_URL=http://localhost:11434
# PRAXIS_LOCAL_MODEL=llama3.1:8b

# ─── Cloud Runtime (OpenAI / Gemini / OpenRouter / Groq) ───────────
# Requires: pip install praxis[cloud]
# PRAXIS_CLOUD_API_KEY=sk-...
# PRAXIS_CLOUD_BASE_URL=https://api.openai.com/v1
# PRAXIS_CLOUD_MODEL=gpt-4o

# ─── Web Research (Brave Search) ───────────────────────────────────
# Free tier, no credit card required.
# Get from: https://brave.com/search/api/
# PRAXIS_WEB_SEARCH_API_KEY=BSA...

# Comma-separated domain allowlist for HTTP requests.
# Every fetch URL is checked — unlisted domains are blocked.
# PRAXIS_ALLOWED_DOMAINS=api.search.brave.com,docs.python.org

# ─── GitHub ─────────────────────────────────────────────────────────
# Personal access token for the `gh` CLI.
# Get from: https://github.com/settings/tokens
# Also requires: gh CLI installed (https://cli.github.com)
# GITHUB_TOKEN=ghp_...

# ─── Email (IMAP read + draft staging) ─────────────────────────────
# Uses IMAP with app-specific passwords (NOT your account password).
# Gmail: https://myaccount.google.com/apppasswords
# Outlook: https://account.microsoft.com/security
# PRAXIS_EMAIL_IMAP_HOST=imap.gmail.com
# PRAXIS_EMAIL_USER=you@gmail.com
# PRAXIS_EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── Calendar (iCal feed read + event proposals) ───────────────────
# Private iCal feed URL (contains embedded auth token).
# Google: Calendar Settings > [calendar] > Secret address in iCal format
# Outlook: Calendar Settings > Shared calendars > Publish a calendar
# PRAXIS_CALENDAR_URL=https://calendar.google.com/calendar/ical/.../basic.ics

# Remember to add calendar domain to PRAXIS_ALLOWED_DOMAINS:
# PRAXIS_ALLOWED_DOMAINS=api.search.brave.com,calendar.google.com

# ─── Queue / Daemon ────────────────────────────────────────────────
# Poll interval in seconds for queue mode (default: 2)
# PRAXIS_QUEUE_POLL_INTERVAL=2

# ─── Slack (push notifications + remote approvals) ─────────────────────────
# Requires: pip install praxis[slack]
#
# Incoming webhook URL — for notify and post_approval_request actions.
# Get from: Slack app > Incoming Webhooks > Add New Webhook to Workspace
# Domain hooks.slack.com must be in PRAXIS_ALLOWED_DOMAINS.
# PRAXIS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
#
# Bot OAuth token — for socket mode listener (python -m praxis --slack-listen).
# Get from: Slack app > OAuth & Permissions > Bot Token (xoxb- prefix)
# PRAXIS_SLACK_BOT_TOKEN=xoxb-...
#
# App-level token — required for socket mode (xapp- prefix, needs connections:write scope).
# Get from: Slack app > Basic Information > App-Level Tokens
# PRAXIS_SLACK_APP_TOKEN=xapp-...
#
# Add both Slack domains to the allowlist:
# PRAXIS_ALLOWED_DOMAINS=api.search.brave.com,hooks.slack.com,slack.com
#
# ─── Telegram (inbound tasks + staged replies) ──────────────────────────────
# Requires: pip install praxis[telegram]
# Get token from BotFather: https://t.me/BotFather → /newbot
# Domain api.telegram.org must be in PRAXIS_ALLOWED_DOMAINS.
# TELEGRAM_BOT_TOKEN=your-bot-token-here

# ─── HEARTBEAT.md proactive triggers ────────────────────────────────────────
# How often (in minutes) the scheduler checks .praxis/HEARTBEAT.md for matching
# time-window sections. Default: 30. Set lower for more responsive triggers.
# PRAXIS_HEARTBEAT_INTERVAL_MINUTES=30

# ─── MCP Gateway (HTTP/SSE) ─────────────────────────────────────────────────
# Requires: pip install praxis[mcp]
# Start with: python -m praxis --mcp
#
# Port for the HTTP/SSE MCP server. Clients connect to http://127.0.0.1:PORT/sse
# PRAXIS_MCP_PORT=8765

# ── Phase X — External integrations ─────────────────────────────────────────

# Cost circuit breaker (all runtimes)
# Sessions exceeding this estimated USD cost will exit(3) and dump a trace.
# For OAuth/subscription users this is approximate (not billed). Raise or
# set very high (e.g. 999999) to effectively disable.
# PRAXIS_MAX_SESSION_COST=2.00

# Notion integration (read + write-escalate via --approve)
# Get from: https://www.notion.so/my-integrations → create integration → copy token
# Add api.notion.com to PRAXIS_ALLOWED_DOMAINS for read actions.
# PRAXIS_NOTION_TOKEN=secret_...

# Linear integration (read + write-escalate via --approve)
# Get from: https://linear.app/settings/api → create API key
# Add api.linear.app to PRAXIS_ALLOWED_DOMAINS for read actions.
# PRAXIS_LINEAR_API_KEY=lin_api_...

# Playwright (browser automation — no additional env var required)
# Install: pip install praxis[playwright] && playwright install chromium
# Add target domains to PRAXIS_ALLOWED_DOMAINS before use.

# =============================================================================
# Scheduled Triggers (Option I)
# =============================================================================
# CronScheduler polls for due tasks on this interval (seconds). Default: 60.
# Starts automatically when running --queue or --daemon.
# Requires: pip install praxis[scheduler]  (installs croniter>=1.0)
PRAXIS_SCHEDULER_POLL_INTERVAL=60

# Built-in useful schedule examples (copy-paste to set up; never auto-enabled):
#
# Morning briefing: every day at 7am — wiki query for today's priorities
#   python -m praxis --schedule-add 'morning-briefing' '0 7 * * *' 'wiki query: what are my priorities for today?'
#
# Linear sync: every hour during work hours (9am–6pm Mon–Fri) — check new issues assigned to you
#   python -m praxis --schedule-add 'linear-sync' '0 9-18 * * 1-5' 'linear list_issues: assigned to me, status todo'
#
# Weekly wiki lint: every Sunday at 9am — surface stale pages, report via Slack
#   python -m praxis --schedule-add 'weekly-wiki-lint' '0 9 * * 0' 'wiki lint: report stale facts and orphan pages'
#
# Schedule management commands:
#   python -m praxis --schedule-list
#   python -m praxis --schedule-enable  <id>
#   python -m praxis --schedule-disable <id>
#   python -m praxis --schedule-remove  <id>
